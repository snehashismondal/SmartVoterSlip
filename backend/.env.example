# Server
NODE_ENV=development
PORT=5000

# Paths (relative to backend root)
VOTERS_JSON_PATH=./database/voters.json
VOTERLIST_PDF_PATH=./pdf/voterlist.pdf

# CORS — comma-separated origins (frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
SEARCH_RATE_LIMIT_MAX=60
PRINT_RATE_LIMIT_MAX=30

# Search
MIN_SEARCH_LENGTH=2
MAX_SEARCH_RESULTS=50

# Cache
SEARCH_CACHE_MAX=500
SEARCH_CACHE_TTL_MS=300000

# Logging
LOG_LEVEL=info
